<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: #F4F6F8;" stylesheets="@../css/style.css" nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mohanad.edufinance.controller.LoginController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox alignment="CENTER" maxWidth="400.0" spacing="25.0" styleClass="card">
        <children>
            <!-- Title -->
            <VBox alignment="CENTER" spacing="5.0">
                <children>
                    <Label text="EduFinance" textFill="#3182CE">
                        <font>
                            <Font name="System Bold" size="32.0" />
                        </font>
                    </Label>
                    <Label text="نظام إدارة الشؤون المالية للمدرسة" textFill="#718096">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </Label>
                </children>
            </VBox>

            <!-- Fields -->
            <VBox spacing="15.0">
                <children>
                    <VBox spacing="5.0">
                        <children>
                            <Label text="اسم المستخدم" textFill="#4A5568">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>
                            <TextField fx:id="usernameField" promptText="أدخل اسم المستخدم" styleClass="text-field" />
                        </children>
                    </VBox>
                    <VBox spacing="5.0">
                        <children>
                            <Label text="كلمة المرور" textFill="#4A5568">
                                <font>
                                    <Font name="System Bold" size="12.0" />
                                </font>
                            </Label>
                            <PasswordField fx:id="passwordField" promptText="أدخل كلمة المرور" styleClass="text-field" />
                        </children>
                    </VBox>
                </children>
            </VBox>

            <!-- Error Message -->
            <Label fx:id="errorLabel" text="اسم المستخدم أو كلمة المرور غير صحيحة" textFill="#E53E3E" visible="false" wrapText="true">
                <font>
                    <Font size="13.0" />
                </font>
            </Label>

            <!-- Submit Button -->
            <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" styleClass="button-primary" text="تسجيل الدخول">
                <font>
                    <Font name="System Bold" size="14.0" />
                </font>
            </Button>
        </children>
        <padding>
            <Insets bottom="35.0" left="35.0" right="35.0" top="35.0" />
        </padding>
    </VBox>
</VBox>
