<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" style="-fx-background-color: #F4F6F8;" stylesheets="@../css/style.css" nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mohanad.edufinance.controller.TeachersController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>
        
        <!-- Right side: Teachers TableView (جدول المعلمين) -->
        <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
            <children>
                <Label text="قائمة أعضاء هيئة التدريس" textFill="#2D3748">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                
                <TableView fx:id="teachersTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="teacherIdCol" prefWidth="50.0" text="المعرف" />
                        <TableColumn fx:id="teacherNameCol" prefWidth="150.0" text="اسم المعلم" />
                        <TableColumn fx:id="teacherPayTypeCol" prefWidth="100.0" text="نوع التعاقد" />
                        <TableColumn fx:id="teacherPayValueCol" prefWidth="120.0" text="القيمة (راتب/حصة)" />
                        <TableColumn fx:id="teacherGradeCol" prefWidth="110.0" text="الصف الدراسي المرتبط" />
                    </columns>
                </TableView>
            </children>
        </VBox>
        
        <!-- Left side: Teacher Form (إدخال وتعديل البيانات) -->
        <VBox spacing="20.0" prefWidth="350.0">
            <children>
                
                <VBox spacing="15.0" styleClass="card" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="إدارة بيانات المعلمين" textFill="#2D3748">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        
                        <VBox spacing="12.0">
                            <children>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="اسم المعلم رباعي" textFill="#4A5568">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="teacherNameField" promptText="أدخل اسم المعلم رباعي" styleClass="text-field" />
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="نوع وطريقة الدفع" textFill="#4A5568">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="payTypeComboBox" promptText="اختر طريقة الدفع" styleClass="text-field" maxWidth="1.7976931348623157E308" />
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label fx:id="payValueLabel" text="قيمة الراتب (ر.ل)" textFill="#4A5568">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="payValueField" promptText="أدخل القيمة المالية" styleClass="text-field" />
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="الصف الدراسي المرتبط (اختياري)" textFill="#4A5568">
                                            <font>
                                                <Font name="System Bold" size="12.0" />
                                            </font>
                                        </Label>
                                        <ComboBox fx:id="teacherGradeComboBox" promptText="اختر الصف الدراسي" styleClass="text-field" maxWidth="1.7976931348623157E308" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                        
                        <VBox VBox.vgrow="ALWAYS" />
                        
                        <HBox spacing="10.0">
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleAddTeacher" prefHeight="35.0" styleClass="button-primary" text="إضافة معلم" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                                <Button mnemonicParsing="false" onAction="#handleEditTeacher" prefHeight="35.0" styleClass="button-primary" style="-fx-background-color: #4A5568;" text="حفظ التعديل" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                                <Button mnemonicParsing="false" onAction="#handleDeleteTeacher" prefHeight="35.0" styleClass="button-danger" text="حذف" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                
            </children>
        </VBox>
        
    </children>
</HBox>
