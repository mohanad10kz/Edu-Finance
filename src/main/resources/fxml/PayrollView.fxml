<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" style="-fx-background-color: #F4F6F8;" stylesheets="@../css/style.css" nodeOrientation="RIGHT_TO_LEFT" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mohanad.edufinance.controller.PayrollController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>
        
        <!-- Right side: Teachers TableView & Filters (تصفية وعرض المعلمين) -->
        <VBox spacing="15.0" styleClass="card" HBox.hgrow="ALWAYS">
            <children>
                <Label text="مسيرات صرف رواتب هيئة التدريس" textFill="#2D3748">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                
                <!-- Filters Bar -->
                <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-background-color: #F7FAFC; -fx-padding: 10; -fx-background-radius: 5;">
                    <children>
                        <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="بحث باسم المعلم" textFill="#4A5568">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="searchNameField" promptText="اكتب اسم المعلم للبحث..." styleClass="text-field" />
                            </children>
                        </VBox>
                        <VBox spacing="3.0" prefWidth="180.0">
                            <children>
                                <Label text="تصفية حسب الصف الدراسي" textFill="#4A5568">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font>
                                </Label>
                                <ComboBox fx:id="gradeFilterComboBox" promptText="كل الصفوف" styleClass="text-field" maxWidth="1.7976931348623157E308" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                
                <!-- Table View -->
                <TableView fx:id="teachersTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="teacherIdCol" prefWidth="50.0" text="المعرف" />
                        <TableColumn fx:id="teacherNameCol" prefWidth="160.0" text="اسم المعلم" />
                        <TableColumn fx:id="teacherPayTypeCol" prefWidth="100.0" text="طريقة الدفع" />
                        <TableColumn fx:id="teacherPayValueCol" prefWidth="120.0" text="القيمة الأساسية" />
                        <TableColumn fx:id="teacherGradeCol" prefWidth="120.0" text="الصف المرتبط" />
                    </columns>
                </TableView>
            </children>
        </VBox>
        
        <!-- Left side: Payroll action (إجراء الصرف المالي) -->
        <VBox spacing="20.0" prefWidth="320.0">
            <children>
                
                <VBox spacing="20.0" styleClass="card" VBox.vgrow="ALWAYS">
                    <children>
                        <Label text="تفاصيل وإجراء الصرف" textFill="#2D3748">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        
                        <!-- Selected Teacher Info Details -->
                        <VBox spacing="12.0" style="-fx-background-color: #F7FAFC; -fx-background-radius: 5; -fx-padding: 15;">
                            <children>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="المعلم المحدد:" textFill="#718096">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="selectedTeacherLabel" text="الرجاء تحديد معلم" textFill="#2D3748">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="طريقة الدفع:" textFill="#718096">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="payTypeLabel" text="-" textFill="#2D3748">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <VBox spacing="3.0">
                                    <children>
                                        <Label fx:id="rateLabel" text="القيمة الأساسية:" textFill="#718096">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="rateValueLabel" text="0.00 ر.ل" textFill="#2D3748">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                        
                        <VBox VBox.vgrow="ALWAYS" />
                        
                        <!-- Process Button -->
                        <Button mnemonicParsing="false" onAction="#handleProcessPayroll" prefHeight="45.0" styleClass="button-primary" style="-fx-background-color: #38A169;" text="صرف المستحقات والرواتب" maxWidth="1.7976931348623157E308">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Button>
                    </children>
                </VBox>
                
            </children>
        </VBox>
        
    </children>
</HBox>
